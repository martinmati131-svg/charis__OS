import rclpy
from rclpy.node import Node
from std_msgs.msg import Bool, Int32
import time

class MotorController(Node):
    def __init__(self):
        super().__init__('motor_controller')
        self.lockdown_sub = self.create_subscription(Bool, '/aura/system/lockdown', self.emergency_stop, 10)
        self.current_rpm = 0
        self.is_locked = False

    def emergency_stop(self, msg):
        if msg.data and not self.is_locked:
            self.get_logger().error("SECURITY BRAKE TRIGGERED: Decelerating NEMA 17...")
            self.is_locked = True
            
            # Controlled Ramping Down (Prevents mechanical shock)
            while self.current_rpm > 0:
                self.current_rpm -= 10 
                self.set_motor_speed(max(0, self.current_rpm))
                time.sleep(0.1) 
                
            self.get_logger().info("System Safely Halted. Actuators Isolated.")

